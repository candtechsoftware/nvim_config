# Ghostty Configuration
# Docs: https://ghostty.org/docs/config/reference

# Appearance
background = #0e0e0e
alpha-blending = linear-corrected

# Font
font-family = Victor Mono
font-size = 14
font-synthetic-style = no-bold, no-italic, no-bold-italic
font-feature = -liga
font-feature = -calt
font-feature = -dlig

# Shell
shell-integration = zsh
shell-integration-features = no-cursor

# Cursor
cursor-style = block
cursor-style-blink = false
cursor-click-to-move = true
mouse-hide-while-typing = true

# Shader
custom-shader = ./shaders/crt.glsl
custom-shader-animation = true

# Keybindings
keybind = cmd+shift+x=close_surface
keybind = cmd+/=toggle_quick_terminal
keybind = cmd+shift+l=new_split:left
keybind = cmd+shift+r=new_split:right
keybind = cmd+shift+h=new_split:down
keybind = cmd+[=goto_split:previous
keybind = cmd+]=goto_split:next
